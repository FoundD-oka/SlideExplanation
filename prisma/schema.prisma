generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Project {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  title     String?
  sourceType String  @map("source_type")
  status    String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  sources  VideoSource[]
  settings ProjectSettings?
  slides   Slide[]
  jobs     Job[]
  exports  ExportRecord[]

  @@map("projects")
}

model VideoSource {
  id               String   @id @default(uuid()) @db.Uuid
  projectId        String   @map("project_id") @db.Uuid
  sourceType       String   @map("source_type")
  youtubeUrl       String?  @map("youtube_url")
  originalFilename String?  @map("original_filename")
  mimeType         String?  @map("mime_type")
  fileSizeBytes    BigInt?  @map("file_size_bytes")
  storageKey       String?  @map("storage_key")
  geminiFileUri    String?  @map("gemini_file_uri")
  durationSeconds  Int?     @map("duration_seconds")
  createdAt        DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id])

  @@map("video_sources")
}

model ProjectSettings {
  id           String   @id @default(uuid()) @db.Uuid
  projectId    String   @unique @map("project_id") @db.Uuid
  slideCount   Int      @map("slide_count")
  audience     String
  theme        String
  imageSize    String   @map("image_size")
  imageQuality String   @map("image_quality")
  outputFormat String   @map("output_format")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id])

  @@map("project_settings")
}

model Slide {
  id                   String   @id @default(uuid()) @db.Uuid
  projectId            String   @map("project_id") @db.Uuid
  slideNumber          Int      @map("slide_number")
  title                String
  description          String
  diagramType          String   @map("diagram_type")
  sourceStartSeconds   Int?     @map("source_start_seconds")
  sourceEndSeconds     Int?     @map("source_end_seconds")
  learningGoal         String   @map("learning_goal")
  mainPoints           Json     @map("main_points")
  visualConcept        String   @map("visual_concept")
  imagePrompt          String   @map("image_prompt")
  speakerNotes         String?  @map("speaker_notes")
  misunderstandingRisk String?  @map("misunderstanding_risk")
  verificationNote     String?  @map("verification_note")
  status               String
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id])
  assets  SlideAsset[]

  @@map("slides")
}

model SlideAsset {
  id                String   @id @default(uuid()) @db.Uuid
  slideId           String   @map("slide_id") @db.Uuid
  projectId         String   @map("project_id") @db.Uuid
  version           Int
  storageKey        String   @map("storage_key")
  width             Int
  height            Int
  format            String
  provider          String
  providerModel     String   @map("provider_model")
  providerRequestId String?  @map("provider_request_id")
  promptHash        String   @map("prompt_hash")
  createdAt         DateTime @default(now()) @map("created_at")

  slide Slide @relation(fields: [slideId], references: [id])

  @@map("slide_assets")
}

model Job {
  id                 String    @id @default(uuid()) @db.Uuid
  projectId          String    @map("project_id") @db.Uuid
  jobType            String    @map("job_type")
  status             String
  currentStep        String?   @map("current_step")
  progressPercent    Int       @default(0) @map("progress_percent")
  currentSlideNumber Int?      @map("current_slide_number")
  totalSlides         Int?     @map("total_slides")
  progressMessage    String?   @map("progress_message")
  errorMessage       String?   @map("error_message")
  cancelledAt        DateTime? @map("cancelled_at")
  startedAt          DateTime? @map("started_at")
  completedAt        DateTime? @map("completed_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id])
  events  JobEvent[]

  @@map("jobs")
}

model JobEvent {
  id        String   @id @default(uuid()) @db.Uuid
  jobId     String   @map("job_id") @db.Uuid
  eventType String   @map("event_type")
  message   String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  job Job @relation(fields: [jobId], references: [id])

  @@map("job_events")
}

model ExportRecord {
  id            String   @id @default(uuid()) @db.Uuid
  projectId     String   @map("project_id") @db.Uuid
  exportType    String   @map("export_type")
  storageKey    String   @map("storage_key")
  fileSizeBytes BigInt?  @map("file_size_bytes")
  status        String
  createdAt     DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id])

  @@map("exports")
}
